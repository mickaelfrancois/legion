@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIcon Icon="@Brand.Helmet" Class="mr-2" />
        <MudText Typo="Typo.h6" Class="mr-6">Legatus</MudText>
        <MudButton Href="/" StartIcon="@Icons.Material.Filled.ViewList" Color="Color.Inherit">Battles</MudButton>
        <MudButton Href="/retex" StartIcon="@Icons.Material.Filled.Handyman" Color="Color.Inherit">RETEX</MudButton>
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@(() => _isDarkMode = !_isDarkMode)" />
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="mt-4 px-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isDarkMode = true;
}
